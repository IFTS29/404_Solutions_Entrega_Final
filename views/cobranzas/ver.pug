extends ../layout

block contenido
  style.
    @media print {
      .no-print { display: none; }
      body { margin: 0; padding: 20px; }
      .cobranza { box-shadow: none; }
    }
    .cobranza {
      max-width: 900px;
      margin: 0 auto;
      background: white;
      border: 1px solid #ddd;
      padding: 20px;
      font-family: monospace;
    }
    .header {
      text-align: center;
      border-bottom: 2px solid #333;
      padding-bottom: 10px;
      margin-bottom: 20px;
    }
    .empresa-nombre { font-size: 1.5rem; font-weight: bold; }
    .empresa-info { font-size: 0.8rem; color: #666; }
    .titulo-cobranza { font-size: 1.3rem; font-weight: bold; text-align: center; margin: 15px 0; }
    .info-grid { display: flex; justify-content: space-between; margin-bottom: 20px; }
    .info-box { border: 1px solid #ccc; padding: 10px; width: 48%; }
    table { width: 100%; border-collapse: collapse; margin: 15px 0; }
    th, td { border: 1px solid #ccc; padding: 8px; text-align: right; }
    th { background-color: #f2f2f2; text-align: center; }
    .text-left { text-align: left; }
    .totales { margin-top: 20px; text-align: right; }
    .firmas { margin-top: 40px; display: flex; justify-content: space-between; }
    .firma-linea { text-align: center; width: 30%; }
    .estatus { font-weight: bold; padding: 5px; text-align: center; border-radius: 4px; }
    .estatus-Pendiente { background-color: #ffc107; color: #333; }
    .estatus-Cobrado { background-color: #28a745; color: white; }
    .estatus-Anulado { background-color: #dc3545; color: white; }

  .cobranza
    .header
      .empresa-nombre TodoStock S.A.
      .empresa-info CUIT: 30-12345678-1
      .empresa-info Dirección: Av. Libertador 1000 - Avellaneda - Bs. As. - Argentina.
      .empresa-info Teléfono: +54 11 2222 3333
      .empresa-info info@todostock.com.ar

    .titulo-cobranza RECIBO DE COBRANZA

    .info-grid
      .info-box
        div
          strong Fecha Impresión: 
          | #{new Date().toLocaleString('es-AR')}
        div
          strong Fecha Emisión: 
          | #{cobranza.fechaEmision.toLocaleDateString('es-AR')}
        div
          strong Estatus: 
          span(class=`estatus estatus-${cobranza.estatus}`)= cobranza.estatus
        div
          strong Número: 
          | #{String(cobranza.numero).padStart(10, '0')}

      .info-box
        div
          strong Cliente: 
          | #{cobranza.clienteInfo.nombre}
        div
          strong DNI/CUIT: 
          | #{cobranza.clienteInfo.nroDoc || 'N/A'}
        div
          strong Dirección: 
          | #{cobranza.clienteInfo.direccion || 'N/A'}
        div
          strong Teléfono: 
          | #{cobranza.clienteInfo.telefono || 'N/A'}

    // Facturas cobradas
    if facturasRelacionadas && facturasRelacionadas.length > 0
      fieldset
        legend Facturas Cobradas
        table
          thead
            tr
              th N° Factura
              th Fecha
              th Total
          tbody
            each factura in facturasRelacionadas
              tr
                td= factura.numero
                td= factura.fecha ? factura.fecha.toLocaleDateString('es-AR') : '-'
                td $ #{factura.total.toLocaleString('es-AR', {minimumFractionDigits: 2})}

    br

    // Formas de cobro
    if cobranza.formasPago && cobranza.formasPago.length > 0
      table
        thead
          tr
            th Forma de Cobro
            th Referencia
            th Caja/Banco: Cuenta
            th Fecha
            th Monto Neto
        tbody
          each pago in cobranza.formasPago
            tr
              td= pago.formaPago
              td= pago.referencia || '-'
              td= pago.bancoCuenta || '-'
              td= new Date(pago.fecha).toLocaleDateString('es-AR')
              td $ #{pago.montoNeto.toLocaleString('es-AR', {minimumFractionDigits: 2})}

    br

    // Total final
    .totales
      hr
      div
        strong Monto Cobrado: 
        | $ #{cobranza.montoCobrado.toLocaleString('es-AR', {minimumFractionDigits: 2})}

    // Observaciones
    if cobranza.observaciones
      .observaciones
        strong Observaciones:
        p= cobranza.observaciones

    br

    // Firmas
    .firmas
      .firma-linea
        if cobranza.elaboradoPor
          br
          strong= cobranza.elaboradoPor
        hr
        | Firma

      .firma-linea
        if cobranza.aprobadoPor
          br
          strong= cobranza.aprobadoPor
        hr
        | Firma

      .firma-linea
        if cobranza.recibiConforme
          br
          strong= cobranza.recibiConforme
        hr
        | Firma

    .firmas
      .firma-linea
        hr
        | Elaborado por

      .firma-linea
        hr
        | Aprobado por

      .firma-linea
        if cobranza.recibiConforme
          br
          strong= cobranza.recibiConforme
        hr
        | Recibido por

    .footer(style="margin-top: 20px; text-align: center; font-size: 0.7rem; border-top: 1px solid #ccc; padding-top: 10px;")
      | https://todostock.com.ar

  // Botones de acción
  .no-print(style="text-align: center; margin-top: 20px;")
    button(onclick="window.print()" style="margin-right: 10px; padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;") 🖨️ Imprimir
    a(href="/cobranzas" style="display: inline-block; padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px;") Volver al listado

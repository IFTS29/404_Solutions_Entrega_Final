extends ../layout

block contenido
  a.btn-volver(href='/cobranzas') Volver
  
  h1= titulo

  if error
    .error-msg= error

  form(action="/cobranzas/nuevo" method="POST" id="formCobranza")
    // Información del Cliente
    fieldset
      legend Datos del Cliente
      div
        label(for="clienteId") Cliente:
        select(name="clienteId" id="clienteId" required)
          option(value="") Seleccione un cliente
          each cliente in clientes
            option(value=cliente.id selected=(datos && datos.clienteId == cliente.id))
              | #{cliente.nombre || cliente.razonSocial} - #{cliente.nroDoc}

      // Botón para cargar facturas
      button(type="button" id="cargarFacturas" style="margin-top: 10px;") Cargar Facturas Pendientes

    // Listado de facturas pendientes
    fieldset(id="facturasContainer" style="display: none;")
      legend Facturas Pendientes
      div(id="facturasListado")
        p Seleccione un cliente y haga clic en "Cargar Facturas"

      div(style="margin-top: 15px;")
        label
          input(type="checkbox" id="seleccionarTodas")
          |  Seleccionar todas

      div(style="margin-top: 10px; font-weight: bold;")
        span Total seleccionado: $ 
        span(id="totalSeleccionado") 0.00

    // Forma de Cobro
    fieldset
      legend Forma de Cobro
      div
        label(for="formaPago") Forma de Cobro:
        select(name="formaPago" id="formaPago" required)
          option(value="Transferencia") Transferencia
          option(value="Efectivo") Efectivo
          option(value="Cheque") Cheque
          option(value="Tarjeta") Tarjeta

      div
        label(for="referencia") Referencia:
        input(type="text" name="referencia" id="referencia" value=datos ? datos.referencia : '')

      div
        label(for="bancoCuenta") Banco/Cuenta:
        input(type="text" name="bancoCuenta" id="bancoCuenta" value=datos ? datos.bancoCuenta : '')

      div
        label(for="fechaCobro") Fecha de Cobro:
        input(type="date" name="fechaCobro" id="fechaCobro" required value=datos ? datos.fechaCobro : new Date().toISOString().split('T')[0])

      div
        label(for="montoACobrar") Monto a Cobrar:
        input(type="number" step="0.01" name="montoACobrar" id="montoACobrar" readonly required style="background-color: #f5f5f5;")

    div.form-actions
      button(type="submit" onclick="return confirmarCobranza()").btn-guardar Generar Cobranza
      a(href="/cobranzas").btn-cancelar Cancelar

  block scripts
    script.
      document.getElementById('cargarFacturas').addEventListener('click', async () => {
        const clienteId = document.getElementById('clienteId').value;
        if (!clienteId) {
          alert('Seleccione un cliente primero');
          return;
        }

        try {
          const res = await fetch(`/cobranzas/facturas-pendientes/${clienteId}`);
          const data = await res.json();

          const container = document.getElementById('facturasContainer');
          const listado = document.getElementById('facturasListado');

          if (!data.success || data.facturas.length === 0) {
            listado.innerHTML = '<p>No hay facturas pendientes para este cliente.</p>';
            container.style.display = 'block';
            return;
          }

          let html = '<table><thead><tr><th>Selec.</th><th>N° Factura</th><th>Fecha</th><th>Total</th></tr></thead><tbody>';
          data.facturas.forEach(f => {
            const fecha = new Date(f.fechaEmision).toLocaleDateString('es-AR');
            html += `<tr>
              <td><input type="checkbox" name="facturasSeleccionadas" value="${f.id}" class="factura-check" data-total="${f.total}"></td>
              <td>${f.numero}</td>
              <td>${fecha}</td>
              <td>$ ${parseFloat(f.total).toLocaleString('es-AR', {minimumFractionDigits: 2})}</td>
            </tr>`;
          });
          html += '</tbody></table>';

          listado.innerHTML = html;
          container.style.display = 'block';

          // Listeners para calcular total
          document.querySelectorAll('.factura-check').forEach(cb => {
            cb.addEventListener('change', calcularTotal);
          });

          // Seleccionar todas
          document.getElementById('seleccionarTodas').addEventListener('change', function() {
            document.querySelectorAll('.factura-check').forEach(cb => {
              cb.checked = this.checked;
            });
            calcularTotal();
          });

        } catch (err) {
          console.error(err);
          alert('Error al cargar facturas');
        }
      });

      function calcularTotal() {
        let total = 0;
        document.querySelectorAll('.factura-check:checked').forEach(cb => {
          total += parseFloat(cb.dataset.total) || 0;
        });
        document.getElementById('totalSeleccionado').textContent = total.toLocaleString('es-AR', {minimumFractionDigits: 2});
        document.getElementById('montoACobrar').value = total.toFixed(2);
      }

      function confirmarCobranza() {
      const cliente = document.getElementById('clienteId');
      const clienteNombre = cliente.options[cliente.selectedIndex].text;
      const total = document.getElementById('totalSeleccionado').textContent;
      const fecha = document.getElementById('fechaCobro').value;

      return confirm(
        `¿Confirmar cobranza?\n\n` +
        `Cliente: ${clienteNombre}\n` +
        `Total: $ ${total}\n` +
        `Fecha: ${fecha}\n\n` +
        `Esta acción marcará las facturas seleccionadas como cobradas.`
      );
    }

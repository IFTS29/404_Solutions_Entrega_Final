extends ../layout

block contenido
  style.
    @media print {
      .no-print { display: none; }
      body { margin: 0; padding: 20px; }
      .factura-container { box-shadow: none; margin: 0; }
    }
    .factura-container {
      max-width: 800px;
      margin: 0 auto;
      background: white;
      border: 1px solid #ddd;
      padding: 20px;
      font-family: 'Courier New', monospace;
    }
    .header {
      text-align: center;
      border-bottom: 2px solid #000;
      padding-bottom: 10px;
      margin-bottom: 20px;
    }
    .empresa-nombre { font-size: 1.3rem; font-weight: bold; }
    .factura-title { font-size: 1.5rem; font-weight: bold; text-align: center; margin: 15px 0; }
    .info-row { display: flex; justify-content: space-between; margin-bottom: 10px; }
    .info-box { border: 1px solid #ccc; padding: 10px; margin-bottom: 15px; }
    .info-cliente { background-color: #f9f9f9; }
    .membrete { background-color: #fff; }
    table { width: 100%; border-collapse: collapse; margin: 15px 0; }
    th, td { border: 1px solid #ccc; padding: 8px; text-align: right; }
    th { background-color: #f2f2f2; text-align: center; }
    .text-left { text-align: left; }
    .totales { margin-top: 20px; text-align: right; border-top: 1px solid #ccc; padding-top: 10px; }
    .estatus { font-weight: bold; padding: 5px; text-align: center; border-radius: 4px; display: inline-block; }
    .estatus-Pendiente { background-color: #ffc107; color: #333; }
    .estatus-Pagada { background-color: #28a745; color: white; }
    .estatus-Anulada { background-color: #dc3545; color: white; }
    .footer { margin-top: 30px; text-align: center; font-size: 0.7rem; border-top: 1px solid #ccc; padding-top: 10px; }

  .factura-container

    .info-box.membrete
      .info-row
        div
          h2 #{factura.empresaInfo.razonSocial}
        div
          h1 A
        div
          h1 FACTURA

      .info-row
        div
          strong Razón Social: 
          | #{factura.empresaInfo.razonSocial}
        div
          strong Factura N°: 
          | #{factura.numero || 'N/A'}

      .info-row  
        div
          strong Dirección: 
          | #{factura.empresaInfo.direccion || 'N/A'}
        div
          strong Fecha Emisión: 
          | #{factura.fechaEmision.toLocaleDateString('es-AR') || 'N/A'}
      .info-row
        div
          strong Argentina
        div
          strong CUIT: 
          | #{factura.empresaInfo.cuit}
      .info-row
        div
          strong Teléfono: 
          | #{factura.empresaInfo.telefono || 'N/A'}
        div
          strong Ingresos Brutos: 
          | #{factura.empresaInfo.ingBrutos || 'N/A'}
      .info-row
        div
          strong Responsable Inscripto
        div
          strong Inicio Actividades: 
          | #{factura.empresaInfo.inicioActividades ? factura.empresaInfo.inicioActividades.toLocaleDateString('es-AR') : 'N/A'}

    .info-box.info-cliente
      .info-row
        div
          strong Razón Social: 
          | #{factura.clienteInfo.razonSocial}
        div
          strong CUIT: 
          | #{factura.clienteInfo.cuit}
      .info-row
        div
          strong Domicilio: 
          | #{factura.clienteInfo.direccion || 'N/A'}
        div
          strong Localidad: 
          | #{factura.clienteInfo.localidad || 'N/A'}
      .info-row
        div
          strong Teléfono: 
          | #{factura.clienteInfo.telefono || 'N/A'}
        div
          strong Provincia: 
          | #{factura.clienteInfo.provincia || 'Buenos Aires'}
      .info-row
        div
          strong Cond. IVA: Responsable Inscripto
        div
          strong Cond. Venta: 
          | Contado

    // Tabla de detalles
    table
      thead
        tr
          th Código
          th Descripción
          th Cantidad
          th P. Unitario
          th Alic. IVA
          th Importe
      tbody
        each detalle in factura.detalles
          tr
            td.text-left= detalle.codigo || '-'
            td.text-left= detalle.descripcion
            td= detalle.cantidad
            td= detalle.precioUnitario.toLocaleString('es-AR', {minimumFractionDigits: 2})
            td= detalle.alicIva
            td= detalle.importe.toLocaleString('es-AR', {minimumFractionDigits: 2})

    // Totales
    .totales
      div
        strong Importe Neto Gravado: 
        | $ #{factura.subtotalNeto.toLocaleString('es-AR', {minimumFractionDigits: 2})}
      div
        strong IVA 21%: 
        | $ #{factura.iva21.toLocaleString('es-AR', {minimumFractionDigits: 2})}
      div
        strong IVA 10,5%: 
        | $ #{factura.iva105.toLocaleString('es-AR', {minimumFractionDigits: 2})}
      div
        strong Importe Otros Tributos: 
        | $ #{factura.otrosTributos.toLocaleString('es-AR', {minimumFractionDigits: 2})}
      hr
      div(style="font-size: 1.2rem; font-weight: bold;")
        strong Total: 
        | $ #{factura.total.toLocaleString('es-AR', {minimumFractionDigits: 2})}

    // CAE
    if factura.cae
      .info-row(style="margin-top: 20px;")
        div
          strong CAE Nº: 
          | #{factura.cae}
        div
          strong Fecha de Vto. de CAE: 
          | #{factura.fechaVtoCAE ? factura.fechaVtoCAE.toLocaleDateString('es-AR') : 'N/A'}

    // Estatus
    .info-row(style="margin-top: 20px;")
      div
        strong Estatus: 
        span(class=`estatus estatus-${factura.estatus}`)= factura.estatus

    // Observaciones
    if factura.observaciones
      .observaciones(style="margin-top: 20px;")
        strong Observaciones:
        p= factura.observaciones

    // Footer ARCA
    .footer
      div ARCA
      div Comprobante Autorizado
      div Esta Administración Federal no se responsabiliza por los datos ingresados en el detalle de la operación

  // Botones de acción
  .no-print(style="text-align: center; margin-top: 20px;")
    button(onclick="window.print()" style="margin-right: 10px; padding: 10px 20px; background-color: #007bff; color: white; border: none; border-radius: 4px; cursor: pointer;") 🖨️ Imprimir
    a(href="/facturas-cliente" style="display: inline-block; padding: 10px 20px; background-color: #6c757d; color: white; text-decoration: none; border-radius: 4px;") Volver al listado
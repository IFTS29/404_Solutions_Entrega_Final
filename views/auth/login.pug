extends ../layout

block contenido
  .login-container
    .login-header
      h1 TodoStock S.A.
      p Iniciar Sesión
    
    if error
      .error-msg= error

    form(action="/login", method="POST")
      div
        label(for="email") E-mail:
        input(type="text", id="email", name="email", value=datos && datos.username ? datos.email : '', required)
      
      div
        label(for="password") Contraseña:
        input(type="password", id="password", name="password", required)
      
      button(type="submit") Iniciar Sesión
    
    .register-link
      p ¿No tienes cuenta? 
        a(href="/register") Regístrate aquí